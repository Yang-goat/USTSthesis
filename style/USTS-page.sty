\RequirePackage{fancyhdr}

\newcommand{\USTSHeaderText}{苏州科技大学本科生毕业论文}

\newcommand{\USTSSetupPageThesis}{%
  \fancyhf{}%
  \fancypagestyle{plain}{%
    \fancyhead[C]{\zihao{5}\songti \USTSHeaderText}%
    \fancyfoot[C]{\zihao{-5}\rmfamily\thepage}%
  }%
  \fancypagestyle{fancy}{%
    \fancyhead[C]{\zihao{5}\songti \USTSHeaderText}%
    \fancyfoot[C]{\zihao{-5}\rmfamily\thepage}%
  }%
  \renewcommand{\headrulewidth}{0.5pt}%
  \pagestyle{fancy}%
}

\newcommand{\USTSSetupPageTranslation}{%
  \fancyhf{}%
  \fancypagestyle{plain}{%
    \fancyhead{}%
    \fancyfoot[C]{\zihao{-5}\rmfamily\thepage}%
  }%
  \fancypagestyle{fancy}{%
    \fancyhead{}%
    \fancyfoot[C]{\zihao{-5}\rmfamily\thepage}%
  }%
  \renewcommand{\headrulewidth}{0pt}%
  \pagestyle{fancy}%
}

\endinput
