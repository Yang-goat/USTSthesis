% ----------------------------------------------------------
% 页眉页脚辅助命令。
%
% thesis / thesisappendix：
% - 有页眉
% - 页码居中放在页脚
%
% translation：
% - 无页眉
% - 页码居中放在页脚
% ----------------------------------------------------------

\RequirePackage{fancyhdr}
\RequirePackage{etoolbox}

\newcommand{\USTSHeaderText}{苏州科技大学本科生毕业论文}
\newcommand{\USTSHeaderTypeThesis}{%
  \renewcommand{\USTSHeaderText}{苏州科技大学本科生毕业论文}%
}
\newcommand{\USTSHeaderTypeDesign}{%
  \renewcommand{\USTSHeaderText}{苏州科技大学本科生毕业设计}%
}
\newcommand{\USTSSetHeaderType}[1]{%
  \ifstrequal{#1}{design}{\USTSHeaderTypeDesign}{%
  \ifstrequal{#1}{thesis}{\USTSHeaderTypeThesis}{%
  \ifstrequal{#1}{毕业设计}{\USTSHeaderTypeDesign}{%
  \ifstrequal{#1}{毕业论文}{\USTSHeaderTypeThesis}{%
    \USTSHeaderTypeThesis%
  }}}}%
}

\newcommand{\USTSSetupPageThesis}{%
  \fancyhf{}%
  \fancypagestyle{plain}{%
    \fancyhead[C]{\zihao{5}\songti \USTSHeaderText}%
    \fancyfoot[C]{\zihao{-5}\rmfamily\thepage}%
  }%
  \fancypagestyle{fancy}{%
    \fancyhead[C]{\zihao{5}\songti \USTSHeaderText}%
    \fancyfoot[C]{\zihao{-5}\rmfamily\thepage}%
  }%
  \renewcommand{\headrulewidth}{0.5pt}%
  \pagestyle{fancy}%
}

\newcommand{\USTSSetupPageTranslation}{%
  \fancyhf{}%
  \fancypagestyle{plain}{%
    \fancyhead{}%
    \fancyfoot[C]{\zihao{-5}\rmfamily\thepage}%
  }%
  \fancypagestyle{fancy}{%
    \fancyhead{}%
    \fancyfoot[C]{\zihao{-5}\rmfamily\thepage}%
  }%
  \renewcommand{\headrulewidth}{0pt}%
  \pagestyle{fancy}%
}

\endinput
